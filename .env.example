# Copy to .env and adjust as needed. All services read configuration from the
# environment; sensible defaults are baked in for local development.

# Environment
APP_ENV=development
LOG_LEVEL=info

# PostgreSQL (POSTGRES_DSN or DATABASE_URL are both accepted)
POSTGRES_DSN=postgres://gpuscheduler:gpuscheduler@localhost:5432/gpuscheduler?sslmode=disable

# Redis (leader election, log cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# API gateway
HTTP_ADDR=:8080
METRICS_ADDR=:9090
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Auth (JWT). Set AUTH_ENABLED=true and a strong JWT_SECRET in production.
AUTH_ENABLED=false
JWT_SECRET=dev-insecure-secret-change-me

# gRPC
SCHEDULER_GRPC_ADDR=localhost:50051
SCHEDULER_GRPC_LISTEN=:50051

# Scheduler tuning
SCHEDULER_ALGORITHM=best-fit        # first-fit | best-fit | priority | fair-share
SCHEDULER_INTERVAL=2s
SCHEDULER_AGING_FACTOR=1.0
SCHEDULER_STARVATION_THRESHOLD=5m
SCHEDULER_ENABLE_PREEMPTION=true
HEARTBEAT_TTL=30s
LEADER_TTL=15s
MAX_RETRIES=3

# Node agent (per node)
NODE_ID=
NODE_GPU_CAPACITY=8
NODE_CPU_CAPACITY=128
NODE_MEMORY_CAPACITY=1024
NODE_GPU_MODEL=A100-80GB
NODE_COST_PER_HOUR=32.77
NODE_SPOT=false
NODE_MEAN_JOB_SECONDS=20

# OpenTelemetry (tracing auto-enables when an endpoint is set)
OTLP_ENDPOINT=
TRACE_SAMPLE_RATIO=1.0
